          }
        }
      ]
    },
    {
      "name": "Contabilitate",
      "item": [
        {
          "name": "Journal entries",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/contabilitate/entries", "host": ["{{baseUrl}}"], "path": ["api", "contabilitate", "entries"] }
          }
        },
        {
          "name": "Trial balance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/contabilitate/balance", "host": ["{{baseUrl}}"], "path": ["api", "contabilitate", "balance"] }
          }
        }
      ]
    },
    {
      "name": "ANAF",
      "item": [
        {
          "name": "CUI lookup (public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/anaf/lookup?cui=12345678",
              "host": ["{{baseUrl}}"],
              "path": ["api", "anaf", "lookup"],
              "query": [{ "key": "cui", "value": "12345678" }]
            }
          }
        },
        {
          "name": "e-Factura inbox",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/anaf/inbox", "host": ["{{baseUrl}}"], "path": ["api", "anaf", "inbox"] }
          }
        },
        {
          "name": "e-Factura inbox sync",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/anaf/inbox/sync", "host": ["{{baseUrl}}"], "path": ["api", "anaf", "inbox", "sync"] }
          }
        }
      ]
    },
    {
      "name": "Banca",
      "item": [
        {
          "name": "List accounts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/banca/accounts", "host": ["{{baseUrl}}"], "path": ["api", "banca", "accounts"] }
          }
        },
        {
          "name": "List transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/banca/transactions?reconciled=false",
              "host": ["{{baseUrl}}"],
              "path": ["api", "banca", "transactions"],
              "query": [{ "key": "reconciled", "value": "false" }]
            }
          }
        }
      ]
    }
  ]
}
